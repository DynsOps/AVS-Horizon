# Workforce Microsoft login
VITE_AZURE_AD_AUTHORITY=https://login.microsoftonline.com/organizations
VITE_AZURE_AD_CLIENT_ID=<workforce-spa-client-id>
VITE_AZURE_AD_REDIRECT_URI=http://localhost:5173/
VITE_AZURE_AD_SCOPE=openid profile email

# External ID local/OTP login
# Browser-side CIAM authority should be the host root only.
VITE_EXTERNAL_ID_AUTHORITY=https://<tenant-name>.ciamlogin.com
VITE_EXTERNAL_ID_CLIENT_ID=<external-id-spa-client-id>
VITE_EXTERNAL_ID_REDIRECT_URI=http://localhost:5173/
VITE_EXTERNAL_ID_SCOPE=openid profile email

# Function API integration
VITE_FUNCTION_API_BASE_URL=http://localhost:7071
# Set true to force real Function API calls in local tests (no mock fallback)
VITE_FORCE_FUNCTION_API=true
# Dev-only: when true, frontend sends x-dev-user-email if hosted ID token is missing
VITE_DEV_BYPASS_AUTH=false
