# Microsoft OAuth (MSAL SPA)
VITE_AZURE_AD_TENANT_ID=your-tenant-id-guid
VITE_AZURE_AD_CLIENT_ID=your-app-registration-client-id
VITE_AZURE_AD_REDIRECT_URI=http://localhost:5173/
VITE_AZURE_AD_SCOPE=openid profile email offline_access User.Read api://<your-client-id>/access_as_user

# Function API integration
VITE_FUNCTION_API_BASE_URL=http://localhost:7071
# Set true to force real Function API calls in local tests (no mock fallback)
VITE_FORCE_FUNCTION_API=true
# Dev-only: when true, frontend sends x-dev-user-email if MS token is missing
VITE_DEV_BYPASS_AUTH=true
