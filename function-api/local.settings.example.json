{
  "IsEncrypted": false,
  "Host": {
    "CORS": "*",
    "CORSCredentials": false
  },
  "Values": {
    "// Runtime": "Azure Functions runtime and local storage emulator",
    "FUNCTIONS_WORKER_RUNTIME": "node",
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "// External ID sign-in": "Backend validates External ID browser ID tokens and provisions local accounts through Graph",
    "EXTERNAL_ID_TENANT_ID": "<external-id-tenant-id>",
    "EXTERNAL_ID_CLIENT_ID": "<external-id-app-client-id>",
    "EXTERNAL_ID_CLIENT_SECRET": "<external-id-app-client-secret>",
    "EXTERNAL_ID_AUDIENCE": "<external-id-spa-client-id-guid>",
    "//": "Backend EXTERNAL_ID_CLIENT_ID is the confidential app used for Graph provisioning. EXTERNAL_ID_AUDIENCE is the browser SPA client id because auth/me now validates ID tokens.",
    "//_comment": "Backend EXTERNAL_ID_AUTHORITY should keep the tenant/policy path because it is used for app-only token acquisition.",
    "EXTERNAL_ID_AUTHORITY": "https://<tenant-name>.ciamlogin.com/<tenant-id-or-domain>/<user-flow>",
    "EXTERNAL_ID_JWKS_URI": "https://<tenant-name>.ciamlogin.com/<tenant-id-or-domain>/discovery/v2.0/keys?p=<user-flow>",
    "EXTERNAL_ID_ISSUER_DOMAIN": "<tenant-name>.onmicrosoft.com",
    "EXTERNAL_ID_ISSUERS": "https://<tenant-name>.ciamlogin.com/<tenant-id>/v2.0/,https://<tenant-name>.ciamlogin.com/<tenant-domain>/v2.0/",
    "EXTERNAL_ID_GRAPH_SCOPE": "https://graph.microsoft.com/.default",
    "// Mail delivery": "Optional separate tenant/app for welcome emails. Falls back to EXTERNAL_ID_* if omitted except sender.",
    "MAIL_TENANT_ID": "<mail-tenant-id>",
    "MAIL_CLIENT_ID": "<mail-app-client-id>",
    "MAIL_CLIENT_SECRET": "<mail-app-client-secret>",
    "MAIL_AUTHORITY": "https://login.microsoftonline.com/<mail-tenant-id>",
    "MAIL_SENDER": "info@your-domain.com",
    "MAIL_LOGIN_URL": "https://your-app-domain/#/login",
    "MAIL_LOGO_URL": "https://horizon.avsglobalsupply.com/assets/avslogo-CA24d8DQ.png",
    "MAIL_GRAPH_SCOPE": "https://graph.microsoft.com/.default",
    "MAIL_SUPPORT_ADMIN_EMAIL": "admin@your-domain.com",
    "// SQL": "Choose ManagedIdentity for Azure or SqlPassword for local development",
    "SQL_SERVER": "<your-sql-server>.database.windows.net",
    "SQL_PORT": "1433",
    "SQL_DATABASE": "<your-database-name>",
    "SQL_AUTH_MODE": "SqlPassword",
    "SQL_USER": "<your-sql-username>",
    "SQL_PASSWORD": "<your-sql-password>",
    "SQL_ENCRYPT": "true",
    "SQL_TRUST_SERVER_CERTIFICATE": "false",
    "// Local development": "Set true only when you intentionally want x-dev-user-email fallback",
    "DEV_BYPASS_AUTH": "true",
    "// Power BI": "Optional reporting integration",
    "POWERBI_TENANT_ID": "<powerbi-tenant-id>",
    "POWERBI_CLIENT_ID": "<powerbi-service-principal-client-id>",
    "POWERBI_CLIENT_SECRET": "<powerbi-service-principal-client-secret>",
    "// Fabric GraphQL": "Optional company chain lookup integration",
    "FABRIC_AAD_SCOPE": "https://api.fabric.microsoft.com/.default",
    "FABRIC_GRAPHQL_ENDPOINT": "https://<graphql-host>/v1/workspaces/<workspace-id>/graphqlapis/<graphql-api-id>/graphql",
    "FABRIC_GRAPHQL_TIMEOUT_MS": "10000",
    "// Fabric Redis Cache": "Optional cache-aside layer for Fabric datasets",
    "REDIS_URL": "redis://localhost:6379",
    "FABRIC_CACHE_ENABLED": "true",
    "FABRIC_CACHE_GROUP_PROJTABLES_TTL_SECONDS": "604800",
    "FABRIC_CACHE_COMPANY_CHAINS_TTL_SECONDS": "86400",
    "FABRIC_CACHE_CONTRACTED_VESSELS_TTL_SECONDS": "86400",
    "FABRIC_CACHE_MERGED_MANDAYS_TTL_SECONDS": "86400",
    "FABRIC_CACHE_PROJ_INVOICE_ITEMS_TTL_SECONDS": "86400"
    
  }
}
